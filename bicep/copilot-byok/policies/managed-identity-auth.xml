<!--
    GitHub Copilot BYOK API Policy
    
    Auth flow:
    1. Extract API key from either api-key header or Authorization: Bearer header
    2. Validate key against named value (no APIM subscription required)
    3. Acquire Azure AD token via managed identity for Cognitive Services
    4. Forward request to Foundry with Bearer token + Host header override
-->
<policies>
    <inbound>
        <!-- CORS must be first to handle preflight before any auth -->
        <cors allow-credentials="false">
            <allowed-origins>
                <origin>*</origin>
            </allowed-origins>
            <allowed-methods preflight-result-max-age="300">
                <method>GET</method>
                <method>POST</method>
                <method>OPTIONS</method>
            </allowed-methods>
            <allowed-headers>
                <header>api-key</header>
                <header>Content-Type</header>
                <header>Authorization</header>
            </allowed-headers>
        </cors>
        <base />
        <!-- Extract key from api-key header or Authorization: Bearer -->
        <set-variable name="client-api-key" value="@(context.Request.Headers.GetValueOrDefault(&quot;api-key&quot;, &quot;&quot;) != &quot;&quot; ? context.Request.Headers.GetValueOrDefault(&quot;api-key&quot;, &quot;&quot;) : (context.Request.Headers.GetValueOrDefault(&quot;Authorization&quot;, &quot;&quot;).StartsWith(&quot;Bearer &quot;) ? context.Request.Headers.GetValueOrDefault(&quot;Authorization&quot;, &quot;&quot;).Substring(7).Trim() : &quot;&quot;))" />
        <!-- Validate against stored named value -->
        <choose>
            <when condition="@((string)context.Variables[&quot;client-api-key&quot;] != &quot;{{copilot-byok-api-key}}&quot;)">
                <return-response>
                    <set-status code="401" reason="Unauthorized" />
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-body>{"error":{"message":"Invalid or missing API key. Provide via api-key header or Authorization: Bearer token.","type":"invalid_request_error","code":"invalid_api_key"}}</set-body>
                </return-response>
            </when>
        </choose>
        <!-- Inject default api-version if not provided (Foundry requires it) -->
        <set-query-parameter name="api-version" exists-action="skip">
            <value>2024-06-01</value>
        </set-query-parameter>
        <!-- Replace client auth with managed identity token for Foundry -->
        <authentication-managed-identity resource="https://cognitiveservices.azure.com/" />
        <set-header name="api-key" exists-action="delete" />
        <set-header name="Ocp-Apim-Subscription-Key" exists-action="delete" />
        <!-- Host header override for TLS (PE uses privatelink URL for routing) -->
        <set-header name="Host" exists-action="override">
            <value>foundry-acw.cognitiveservices.azure.com</value>
        </set-header>
        <!-- Rate limit: 60 requests per minute per key -->
        <rate-limit-by-key calls="60" renewal-period="60" counter-key="@((string)context.Variables[&quot;client-api-key&quot;])" />
    </inbound>
    <backend>
        <forward-request timeout="120" follow-redirects="true" buffer-request-body="true" />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
