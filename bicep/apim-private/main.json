      "type": "string",
      "defaultValue": "10.1.0.128/27",
      "metadata": {
        "description": "CIDR prefix for APIM integration subnet (outbound)"
      }
    },
    "ppSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.1.1.0/27",
