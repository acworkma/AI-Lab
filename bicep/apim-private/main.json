            "value": "[parameters('vpnClientAddressPool')]"
          },
          "apimSubnetPrefix": {
            "value": "[parameters('apimSubnetPrefix')]"
          },
          "tags": {
            "value": "[parameters('tags')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.40.2.10011",
              "templateHash": "2081577727175711674"
            }
          },
          "parameters": {
            "nsgName": {
              "type": "string",
              "defaultValue": "nsg-apim-integration",
              "metadata": {
                "description": "Name of the NSG"
              }
            },
            "location": {
              "type": "string",
              "metadata": {
