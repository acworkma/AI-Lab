# GitHub Copilot BYOK - Environment Variables
#
# Copy this file to .env and fill in the values after running deploy-copilot-byok.sh
# The deploy script will auto-populate these values on successful deployment.
#
# IMPORTANT: Never commit .env to source control. It is already in .gitignore.

# APIM subscription key — this is the "API key" you enter in GitHub Enterprise settings
APIM_SUBSCRIPTION_KEY=<your-apim-subscription-key>

# APIM gateway URL — used to construct the deployment URL for GitHub Enterprise
APIM_GATEWAY_URL=<your-apim-gateway-url>

# Foundry model deployment name — this is the "Model ID" in GitHub Enterprise settings
FOUNDRY_DEPLOYMENT_NAME=gpt-5.1-codex-mini
